{
    "name": "Easy Double Entry",
    "namespace": "CCHMC\\EasyDoubleEntry",
    "framework-version": 14,
    "description": "Simple, upgrade-safe double data entry using repeat instances. Pick which instruments and fields need DDE — skip clinician-only items. Any authorized user enters Round 1 or Round 2 with no special roles. Includes dashboard, task list, and side-by-side comparison with one-click merge.",
    "documentation": "README.md",
    "authors": [
        {
            "name": "Ernest Pedapati",
            "email": "ernest.pedapati@cchmc.org",
            "institution": "Cincinnati Children's Hospital Medical Center"
        }
    ],
    "enable-every-page-hooks-on-system-pages": false,
    "enable-ajax-logging": true,
    "auth-ajax-actions": [
        "get-record-rounds",
        "compare-rounds",
        "merge-field",
        "merge-bulk",
        "get-dashboard-data",
        "get-dde-stats",
        "get-task-list"
    ],
    "links": {
        "project": [
            {
                "name": "DDE Dashboard",
                "icon": "fas fa-columns",
                "url": "pages/dashboard.php",
                "show-header-and-footer": true
            },
            {
                "name": "DDE Comparison & Merge",
                "icon": "fas fa-not-equal",
                "url": "pages/compare.php",
                "show-header-and-footer": true
            },
            {
                "name": "DDE Task List",
                "icon": "fas fa-tasks",
                "url": "pages/tasklist.php",
                "show-header-and-footer": true
            }
        ]
    },
    "compatibility": {
        "redcap-version-min": "13.0.0",
        "php-version-min": "8.0"
    },
    "project-settings": [
        {
            "key": "dde-instruments-header",
            "name": "<b style='font-size:14px;'>Which instruments need double data entry?</b><br>Add each instrument below. Optionally list variable names to skip during comparison (e.g., clinician-only validity items that don't need DDE).",
            "type": "descriptive"
        },
        {
            "key": "dde-instrument-config",
            "name": "<b>Instrument</b>",
            "type": "sub_settings",
            "repeatable": true,
            "sub_settings": [
                {
                    "key": "dde-instrument",
                    "name": "Instrument",
                    "type": "form-list"
                },
                {
                    "key": "dde-exclude-fields",
                    "name": "Skip these variables during comparison <i>(comma-separated, leave blank to compare all)</i>",
                    "type": "textarea"
                }
            ]
        },
        {
            "key": "filtering-header",
            "name": "<b style='font-size:14px;'>Who sees which instruments on the dashboard?</b><br>Optional. Use rules below to show different instruments for different participants based on a field value (e.g., only show ADOS for participants in the ASD cohort). Leave blank to show all instruments for everyone.",
            "type": "descriptive"
        },
        {
            "key": "filter-rules",
            "name": "<b>Rule</b>",
            "type": "sub_settings",
            "repeatable": true,
            "sub_settings": [
                {
                    "key": "filter-field",
                    "name": "When this field",
                    "type": "field-list"
                },
                {
                    "key": "filter-value",
                    "name": "equals this value",
                    "type": "text"
                },
                {
                    "key": "filter-instruments",
                    "name": "then show these instruments on the dashboard <i>(comma-separated form names, or type 'all')</i>",
                    "type": "textarea"
                }
            ]
        },
        {
            "key": "merge-header",
            "name": "<b style='font-size:14px;'>Merge settings</b>",
            "type": "descriptive"
        },
        {
            "key": "merge-target-instance",
            "name": "Where should merged values be saved?",
            "type": "dropdown",
            "choices": [
                { "name": "Overwrite Round 1 (Instance 1)", "value": "1" },
                { "name": "Save to a new Final instance (Instance 3)", "value": "3" }
            ]
        },
        {
            "key": "require-merge-comment",
            "name": "Require a comment when resolving discrepancies",
            "type": "checkbox"
        },
        {
            "key": "notification-email",
            "name": "Send email when both rounds are complete <i>(optional, leave blank to disable)</i>",
            "type": "text"
        }
    ]
}
